{
  "title": "Loan Eligibility Agent",
  "uid": "loan-agent-v1",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate by Verdict",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(loan_requests_total[1m])",
          "legendFormat": "{{verdict}} / {{employment_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "loan_active_requests",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(loan_requests_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }
      }
    },
    {
      "id": 4,
      "title": "Eligible vs Not Eligible",
      "type": "piechart",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 8 },
      "targets": [
        {
          "expr": "sum by (verdict) (loan_requests_total)",
          "legendFormat": "{{verdict}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Agent Failures",
      "type": "stat",
      "gridPos": { "x": 12, "y": 4, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(agent_failures_total)",
          "legendFormat": "Failures",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Failure Rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 4, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(agent_failures_total[5m]))",
          "legendFormat": "Failures/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 7,
      "title": "Processing Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(loan_processing_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(loan_processing_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(loan_processing_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 8,
      "title": "DTI Ratio Distribution",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(applicant_dti_ratio_bucket[5m]))",
          "legendFormat": "p50 DTI",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, rate(applicant_dti_ratio_bucket[5m]))",
          "legendFormat": "p90 DTI",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.35 },
              { "color": "red", "value": 0.40 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Agent Failures by Agent",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(agent_failures_total[5m])",
          "legendFormat": "{{agent_name}} / {{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 10,
      "title": "LLM Token Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(llm_tokens_total[5m])",
          "legendFormat": "{{agent_name}} / {{token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 11,
      "title": "Tokens per Request Distribution",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(llm_tokens_per_request_bucket[5m]))",
          "legendFormat": "p50 tokens",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(llm_tokens_per_request_bucket[5m]))",
          "legendFormat": "p95 tokens",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 12,
      "title": "MCP Call Success / Failure Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(mcp_calls_total[5m])",
          "legendFormat": "{{server_name}} / {{tool_name}} / {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    }
  ]
}
