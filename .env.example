# Copy this file to .env and fill in your Anthropic API key
# cp .env.example .env

# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Override default model (default: claude-opus-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Override MCP server ports
# MCP_LOAN_RULES_PORT=8765
# MCP_AUDIT_PORT=8766

# Optional: Override Prometheus metrics port
# PROMETHEUS_PORT=9090
